  "org": "FlexNetOS",
  "description": "Canonical registry of MCP servers used across the FlexNetOS meta workspace.",
  "servers": [
    {
      "id": "meta",
      "displayName": "meta-mcp",
      "kind": "local",
      "runner": "binary",
      "transport": "stdio",
      "command": "meta-mcp",
      "args": [],
      "repo": "git@github.com:FlexNetOS/meta_mcp.git",
      "workspaceMember": "meta_mcp",
      "status": "stable",
      "toolPrefix": "meta_",
      "toolCount": 29,
      "auth": "none",
      "summary": "Multi-repo operations for the meta workspace: project listing, cross-repo git, build/test orchestration, code search, dependency/impact analysis, and snapshots.",
      "doc": "servers/meta_mcp.md",
      "snippet": "snippets/meta.mcp.json"
    },
    {
      "id": "weave",
      "displayName": "weave",
      "kind": "local",
      "runner": "binary",
      "transport": "stdio",
      "command": "weave",
      "args": [
        "mcp"
      ],
      "repo": "git@github.com:FlexNetOS/weave.git",
      "workspaceMember": "weave",
      "status": "stable",
      "toolPrefix": "weave_",
      "toolCount": 11,
      "auth": "none",
      "summary": "Rust-native agent-to-agent session mesh. Lets coding-agent sessions message each other and pushes live nudges into a peer's tmux/zellij pane.",
      "doc": "servers/weave.md",
      "snippet": "snippets/weave.mcp.json"
    },
    {
      "id": "n8n-mcp",
      "displayName": "n8n-mcp",
      "kind": "external",
      "runner": "npx",
      "transport": "stdio",
      "command": "npx",
      "args": [
        "n8n-mcp"
      ],
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "error",
        "DISABLE_CONSOLE_OUTPUT": "true",
        "N8N_API_URL": "https://your-n8n-instance.com",
        "N8N_API_KEY": "<your-n8n-api-key>"
      },
      "repo": "git@github.com:FlexNetOS/n8n-mcp.git",
      "status": "stable",
      "auth": "api-key",
      "requiresApi": true,
      "summary": "Build and manage n8n workflows from an agent. 7 core node-documentation/validation tools work with no credentials; 13 management tools (create/update/run workflows, executions, credentials) require an n8n API URL + key.",
      "doc": "servers/n8n-mcp.md",
      "snippet": "snippets/n8n-mcp.mcp.json",
      "notes": "Fork of czlonkowski/n8n-mcp (TypeScript, MIT). Runs via `npx n8n-mcp` or the ghcr.io/czlonkowski/n8n-mcp Docker image. Not a meta workspace member."
    },
